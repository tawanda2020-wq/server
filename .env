PORT=3000

# Shared secret the ESP32 firmware must send in the X-Device-Secret header.
# Must match DEVICE_SHARED_SECRET in esp32-firmware/ChildTracker/config.h
DEVICE_SHARED_SECRET=GPS_BASED_CHILD_TRACKING_SYSTEM_@Ashie2026

# Demo parent login (single-parent prototype demo; see docs/SETUP_GUIDE.md
# for how to add more accounts).
DEMO_USERNAME=parent
DEMO_PASSWORD=demo1234

# Session cookie signing secret
SESSION_SECRET=@Ashie.T.Chinake_GPS-BASED_CHILD_TRACKING_SYSTEM_2026

# SQLite database file path (relative to server/ folder)
DB_PATH=./data/tracker.db
